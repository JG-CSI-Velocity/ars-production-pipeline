print("\n📊 A[X].30 - Analyzing ICS Stat Code O Cohort Milestones...")

# Get ICS Stat Code O accounts with debit cards
ics_stat_o = data[(data['ICS Account'] == 'Yes') & (data['Stat Code'] == '0') & (data['Debit?'] == 'Yes')].copy()

# Convert Date Opened to datetime
ics_stat_o['Date Opened'] = pd.to_datetime(ics_stat_o['Date Opened'], errors='coerce')
ics_stat_o['Opening Month'] = ics_stat_o['Date Opened'].dt.to_period('M').astype(str)

# Build simplified cohort analysis - only milestones
cohort_milestones = []

# Get current year
current_year = pd.Timestamp.now().year

# Get unique opening months and organize them - filter to 2023 and later
all_opening_months = sorted([m for m in ics_stat_o[ics_stat_o['Opening Month'].notna()]['Opening Month'].unique() if m >= '2023-01'])

# Separate into:
# 1. Complete previous years (aggregated by year) - 2023 and later only
# 2. Current year months (individual months)
opening_periods = []

# Add complete previous years (2023 and later)
previous_years = sorted(set([m[:4] for m in all_opening_months if int(m[:4]) < current_year and int(m[:4]) >= 2023]))
for year in previous_years:
    opening_periods.append(year)  # Just the year, e.g., "2023"

# Add current year individual months
current_year_months = sorted([m for m in all_opening_months if int(m[:4]) == current_year])
opening_periods.extend(current_year_months)

# Define milestone months
milestones = [1, 3, 6, 9, 12]

for opening_period in opening_periods:
    # Check if this is a year (4 chars) or a month (7 chars like "2025-01")
    if len(opening_period) == 4:
        # This is a full year - aggregate all months from that year
        cohort = ics_stat_o[ics_stat_o['Opening Month'].str.startswith(opening_period)].copy()
        period_label = opening_period
    else:
        # This is a specific month
        cohort = ics_stat_o[ics_stat_o['Opening Month'] == opening_period].copy()
        period_label = opening_period
    
    if len(cohort) == 0:
        continue
    
    cohort_row = {
        'Opening Period': period_label,
        'Cohort Size': len(cohort),
        'Avg Current Balance': round(cohort['Curr Bal'].mean(), 2)
    }
    
    # For each milestone month
    for milestone in milestones:
        # For year aggregations, use first month of year as baseline
        if len(opening_period) == 4:
            opening_date = pd.to_datetime(f"{opening_period}-01")
        else:
            opening_date = pd.to_datetime(opening_period)
        
        target_date = opening_date + pd.DateOffset(months=milestone-1)
        target_month_str = target_date.strftime('%b%y')
        
        swipe_col = f"{target_month_str} Swipes"
        spend_col = f"{target_month_str} Spend"
        
        # Check if this month is in the future or doesn't exist in data
        if swipe_col in cohort.columns and spend_col in cohort.columns:
            # Check if this milestone month has actually occurred
            if target_month_str in last_12_months:
                total_swipes = cohort[swipe_col].sum()
                total_spend = cohort[spend_col].sum()
                active_count = (cohort[swipe_col] > 0).sum()
                
                cohort_row[f'M{milestone} Active'] = active_count
                cohort_row[f'M{milestone} % Active'] = round((active_count / len(cohort)), 2) if len(cohort) > 0 else 0
                cohort_row[f'M{milestone} Avg Swipes'] = round(cohort[swipe_col].mean(), 2)
                cohort_row[f'M{milestone} Avg Spend'] = round(cohort[spend_col].mean(), 2)
            else:
                # Future month - leave blank (empty string)
                cohort_row[f'M{milestone} Active'] = ''
                cohort_row[f'M{milestone} % Active'] = ''
                cohort_row[f'M{milestone} Avg Swipes'] = ''
                cohort_row[f'M{milestone} Avg Spend'] = ''
        else:
            # Month doesn't exist in data - leave blank
            cohort_row[f'M{milestone} Active'] = ''
            cohort_row[f'M{milestone} % Active'] = ''
            cohort_row[f'M{milestone} Avg Swipes'] = ''
            cohort_row[f'M{milestone} Avg Spend'] = ''
    
    cohort_milestones.append(cohort_row)

ax25_cohort_milestones = pd.DataFrame(cohort_milestones)

# Display
display_formatted(ax25_cohort_milestones, "ICS Stat Code O - Cohort Milestones (M1, M3, M6, M9, M12)")

print(f"\n✅ Analysis completed")
print(f"   Total Cohorts Analyzed: {len(ax25_cohort_milestones)}")
print(f"   Showing: 2023+ (Previous Complete Years + Current Year Monthly)")

# Calculate average retention rates for each milestone
if len(ax25_cohort_milestones) > 0:
    print(f"\n📈 Average Retention Rates Across Cohorts:")
    for milestone in milestones:
        col = f'M{milestone} % Active'
        if col in ax25_cohort_milestones.columns:
            # Filter out empty strings and calculate average
            valid_values = ax25_cohort_milestones[ax25_cohort_milestones[col] != ''][col]
            if len(valid_values) > 0:
                avg_retention = valid_values.mean()
                print(f"   M{milestone}: {avg_retention:.1f}% (based on {len(valid_values)} cohort(s))")
